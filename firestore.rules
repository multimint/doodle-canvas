rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any authenticated user can read (needed for invite-by-email lookup);
    // only the owner can write their own doc
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }

    // Canvases
    match /canvases/{canvasId} {
      function isAuthenticated() {
        return request.auth != null;
      }
      function isOwner() {
        return resource.data.ownerId == request.auth.uid;
      }
      function isMember() {
        return request.auth.uid in resource.data.members;
      }
      function canAccess() {
        return isOwner() || isMember();
      }

      allow read: if isAuthenticated() && canAccess();

      // Create: user must be authenticated and under the 10-canvas limit
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canvasCount < 10;

      // Update: owner can update anything; members can update snapshotUrl/snapshotStrokeId/updatedAt
      allow update: if isAuthenticated() && (
        isOwner()
        || (isMember() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['snapshotUrl', 'snapshotStrokeId', 'updatedAt']))
      );

      allow delete: if isAuthenticated() && isOwner();
    }
  }
}
