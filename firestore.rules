rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any authenticated user can read (needed for invite-by-email lookup);
    // only the owner can write their own doc
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }

    // Canvases
    match /canvases/{canvasId} {
      function isAuthenticated() {
        return request.auth != null;
      }
      function isOwner() {
        return resource.data.ownerId == request.auth.uid;
      }
      function isMember() {
        return request.auth.uid in resource.data.members;
      }
      function canAccess() {
        return isOwner() || isMember();
      }

      allow read: if isAuthenticated() && canAccess();

      // Create: user must be authenticated and under the 10-canvas limit
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canvasCount < 10;

      // Update: owner can update anything; members can update snapshot fields;
      // an invited user can accept their own invite (move uid→members, email→remove from pendingInvites)
      allow update: if isAuthenticated() && (
        isOwner()
        || (isMember() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['snapshotUrl', 'snapshotStrokeId', 'snapshotStrokeIds', 'snapshotAt', 'updatedAt']))
        || (request.auth.token.email in resource.data.pendingInvites
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'pendingInvites'])
            && request.auth.uid in request.resource.data.members
            && request.resource.data.members.size() == resource.data.members.size() + 1
            && !(request.auth.token.email in request.resource.data.pendingInvites)
            && request.resource.data.pendingInvites.size() == resource.data.pendingInvites.size() - 1)
      );

      allow delete: if isAuthenticated() && isOwner();

      // Stroke snapshot subcollection — durable Firestore mirror of RTDB strokes
      // canAccess() cannot be reused here: `resource` resolves to the stroke doc
      // inside this block, not the canvas doc. Fetch the parent explicitly.
      match /strokes/{strokeId} {
        function canvasData() {
          return get(/databases/$(database)/documents/canvases/$(canvasId)).data;
        }
        allow read: if isAuthenticated() && (
          canvasData().ownerId == request.auth.uid ||
          request.auth.uid in canvasData().members
        );
        allow write: if isAuthenticated() && (
          canvasData().ownerId == request.auth.uid ||
          request.auth.uid in canvasData().members
        );
      }
    }
  }
}
